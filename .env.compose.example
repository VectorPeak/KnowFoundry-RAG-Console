APP_ENV=dev
APP_ROOT_PATH=
LOG_LEVEL=INFO
ACTIVE_SCENARIO_ID=enterprise_knowledge
API_PORT=8000
ENV_FILE=.env.compose

# Compose mode: run FastAPI inside docker compose, access dependencies by service name.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=subjects_kg

MILVUS_URI=http://milvus:19530
MILVUS_DATABASE=

LLM_MODEL=qwen-plus
DASHSCOPE_API_KEY=请替换为真实可用的模型服务 Key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=60

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=请替换为 LangSmith API Key
LANGSMITH_PROJECT=knowforge-rag-platform
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

EMBEDDING_MODEL_PATH=/app/models/bge-m3
RERANKER_MODEL_PATH=/app/models/bge-reranker-large
EMBEDDING_MODEL_VERSION=bge-m3-local-v1
RERANKER_MODEL_VERSION=bge-reranker-large-local-v1
CHUNK_SCHEMA_VERSION=parent_child_v1

CUSTOMER_SERVICE_PHONE=12345678
CORS_ALLOW_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
ADMIN_API_TOKEN=请替换为随机长令牌
API_RATE_LIMIT_PER_MINUTE=120
